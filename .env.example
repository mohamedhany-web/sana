APP_NAME=Sana
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# CSP: مع APP_DEBUG=true الافتراضي يعطّل CSP (DISABLE_CSP غير معرّف = true). لاختبار صفحة الدفع وفواتيرك محلياً بـ CSP: DISABLE_CSP=false
# DISABLE_CSP=false
# على السيرفر المباشر: استخدم رابط الموقع الحقيقي (مثلاً https://yourdomain.com) وإلا لا تظهر الصور
APP_URL=http://localhost

# Google OAuth (تسجيل الدخول / إنشاء حساب طالب بـ Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# قرص ملفات مجتمع الذكاء الاصطناعي (تقديمات المساهمين): local أو r2
FILESYSTEM_DISK_COMMUNITY=local
# الإنتاج: فعّل الرفع والعرض عبر Cloudflare R2 لكل الشعارات والصور المرفوعة من لوحة الأدمن
USE_CLOUDFLARE_R2=false
# أو اضبط كل قرص يدوياً (تُتجاهل عند USE_CLOUDFLARE_R2=true إن لم تُحدّد):
# ADMIN_BRANDING_DISK=r2
# SITE_SERVICES_DISK=r2
# SITE_TESTIMONIALS_DISK=r2
# USER_PROFILE_DISK=r2
# ASSIGNMENT_FILES_DISK=r2
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# البريد: لإرسال رمز المصادقة الثنائية (2FA) للأدمن والمدربين عبر SMTP
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=info@mualimx.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=info@mualimx.com
MAIL_FROM_NAME="${APP_NAME}"

# تنبيه فوري لتذاكر الدعم الفني (عنوان أو أكثر مفصولة بفاصلة — يُفضّل Gmail أو بريد يُراقبونه دائماً)
SUPPORT_ALERT_EMAIL=

# إلزام الأدمن والمدربين بالمصادقة الثنائية (2FA) عبر البريد
ADMIN_2FA_REQUIRED=true

# عام (S3 أو Cloudflare R2)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
# لـ Cloudflare R2: Endpoint من لوحة R2 → Manage R2 API Tokens
# AWS_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
# رابط عام للتحميل — مطلوب لعرض الصور في المتصفح (R2 → bucket → Settings → Public access → R2.dev subdomain)
# AWS_URL=https://pub-xxxxxxxx.r2.dev
# أو نطاق مخصّص: AWS_URL=https://cdn.example.com
AWS_URL=
# بديل لـ AWS_URL إن رغبت بفصله
# R2_PUBLIC_URL=
# عرض ملفات R2 عبر /storage/ على نفس الموقع (لا يحتاج symlink ولا exec — موصى به على Hostinger)
STORAGE_SERVE_VIA_APP=true
# عند نشر public داخل public_html (Hostinger): المسار الكامل لمجلد الموقع
# PUBLIC_WEB_ROOT=/home/u123456/domains/sanaedu.com/public_html

# بوابة الدفع كاشير — API v3 (Payment Sessions). TEST → test-api.kashier.io ، LIVE → api.kashier.io
KASHIER_MODE=test
KASHIER_TEST_MID=
KASHIER_TEST_API_KEY=
KASHIER_TEST_SECRET=
KASHIER_TEST_BASE_URL=https://checkout.kashier.io
# KASHIER_TEST_API_BASE_URL=https://test-api.kashier.io
KASHIER_LIVE_MID=
KASHIER_LIVE_API_KEY=
KASHIER_LIVE_SECRET=
KASHIER_LIVE_BASE_URL=https://checkout.kashier.io
# KASHIER_LIVE_API_BASE_URL=https://api.kashier.io
APP_CURRENCY=SAR
KASHIER_CURRENCY=SAR
KASHIER_ALLOWED_METHODS=card,wallet,bank_installments
# رابط العودة بعد الدفع — يجب أن يكون URI صالحاً. للتجربة محلياً: http://127.0.0.1:8000/checkout/kashier/callback
# KASHIER_MERCHANT_REDIRECT_URL=https://yourdomain.com/checkout/kashier/callback

# ─── Muallimx AI (توليد نصوص — مفاتيح المزوّد) ───
# أنشئ مفتاحاً من لوحة المزوّد (مثلاً AI Studio) ثم الصقه هنا
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_HTTP_TIMEOUT=60
GEMINI_MAX_OUTPUT_TOKENS=8192
# Optional: larger cap for educational game HTML generation
# GEMINI_MAX_OUTPUT_TOKENS_GAME=16384

VITE_APP_NAME="${APP_NAME}"

# حد رفع الملفات للتطبيق (كيلوبايت). 40960 = 40 ميجابايت — يُنصح بضبط PHP/nginx مع Cloudflare
# MAX_UPLOAD_KB=40960
# MAX_UPLOAD_BYTES=41943040

# مواد مكتبة المناهج (رفع إلى R2): 150 × 1024 = 153600 كيلوبايت ≈ 150 ميجابايت — اضبط PHP: upload_max_filesize و post_max_size بما لا يقل عن ذلك
# CURRICULUM_MATERIAL_MAX_UPLOAD_KB=153600

# من هذا الحجم (بايت) يُستخدم رفع R2 متعدد الأجزاء بدل PUT واحد — الافتراضي 12 ميجابايت
# CURRICULUM_R2_MULTIPART_THRESHOLD_BYTES=12582912
# حجم كل جزء (بايت، ≥ 5MB حسب S3). افتراضي 16 ميجابايت — أجزاء أقل وأقل عرضة لأخطاء CORS بين المتصفح وR2
# CURRICULUM_R2_MULTIPART_PART_BYTES=16777216
# true = جرّب PUT مباشر للمتصفح→R2 ثم الاحتياطي عبر الخادم عند الفشل؛ false = كل الأجزاء عبر الخادم (يتجاوز CORS)
# CURRICULUM_R2_MULTIPART_BROWSER_FIRST=true

# شهادة المنصة التلقائية عند إتمام الكورس (PDF بتصميم أكاديمي)
# CERTIFICATE_PLATFORM_AUTO_ON_COMPLETE=true
# CERTIFICATE_ACADEMY_NAME=
# CERTIFICATE_COLOR_PRIMARY=#283593
# CERTIFICATE_COLOR_SECONDARY=#FB5607
# CERTIFICATE_DIRECTOR_NAME=
# CERTIFICATE_DIRECTOR_TITLE=
